# Django core settings
# Railway / production variable names use the DJANGO_ prefix.
# Non-prefixed names are still accepted for backward compatibility.
DJANGO_SECRET_KEY=
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

# Railway / Heroku PostgreSQL connection string.
# When set, this overrides the local DB_* variables below.
DATABASE_URL=

# Local PostgreSQL settings (used when DATABASE_URL is absent).
DB_NAME=sidrahsoft_db
DB_USER=sidrahsoft_user
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,ar

MEDIA_URL=/media/
STATIC_URL=/static/

# Session cookie age in seconds (default: 28800 = 8 hours)
SESSION_COOKIE_AGE=28800

# Email configuration
# For local development, console backend prints emails to the terminal.
# For production, use django.core.mail.backends.smtp.EmailBackend and provide
# EMAIL_HOST, EMAIL_HOST_USER, and EMAIL_HOST_PASSWORD.
# Gmail requires a Google App Password (not your normal Gmail password).
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=Sidrah Soft <sidrahsoft@gmail.com>
SERVER_EMAIL=

# Leads Dashboard configuration
CONTACT_NOTIFICATION_EMAIL=
LEADS_DASHBOARD_BASE_URL=
